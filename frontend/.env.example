# API endpoint (set automatically by Terraform deploy; only needed for local dev against a live backend)
# REACT_APP_API_ENDPOINT=https://your-cloudfront-domain.cloudfront.net/api

# AWS region (used for display purposes)
# REACT_APP_AWS_REGION=us-east-1

# Okta SSO (leave blank or omit to use local auth)
# REACT_APP_OKTA_DOMAIN=your-org.okta.com
# REACT_APP_OKTA_CLIENT_ID=0oa...

# Azure AD / Entra ID SSO (leave blank or omit to use local auth)
# REACT_APP_AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# REACT_APP_AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# NOTE: Configure only ONE identity provider at a time (Okta or Azure AD).

# Local auth credentials (only used when Okta is not configured)
# NOTE: These are baked into the JS bundle at build time and visible in page source.
# Local auth is a development convenience, not a security boundary. Use Okta for production.
# REACT_APP_LOCAL_ADMIN_USERNAME=admin
# REACT_APP_LOCAL_ADMIN_PASSWORD=admin123

# API key for backend auth (auto-generated by Terraform; only override for local dev against a live backend)
# REACT_APP_LOCAL_API_KEY=

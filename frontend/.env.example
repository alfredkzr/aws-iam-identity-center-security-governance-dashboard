# API endpoint (set automatically by Terraform deploy; only needed for local dev against a live backend)
# REACT_APP_API_ENDPOINT=https://your-cloudfront-domain.cloudfront.net/api

# AWS region (used for display purposes)
# REACT_APP_AWS_REGION=us-east-1

# Okta SSO (leave blank or omit to use local auth)
# REACT_APP_OKTA_DOMAIN=your-org.okta.com
# REACT_APP_OKTA_CLIENT_ID=0oa...

# Local auth credentials (only used when Okta is not configured)
# REACT_APP_LOCAL_ADMIN_USERNAME=admin
# REACT_APP_LOCAL_ADMIN_PASSWORD=admin123
